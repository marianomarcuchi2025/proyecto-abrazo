# Copiar a .env y ajustar antes de desplegar. Nunca commitear el .env real.

# Origen permitido para CORS. NO usar "*" en producción.
CORS_ORIGIN=http://localhost:3000

# Puerto del backend
PORT=3001

# Carpeta donde el servidor persiste postales.json y alertas.json (JSON en
# disco, no una base de datos real — ver packages/server/src/persistence.ts).
# Default si se omite: ./data relativo a donde se ejecuta el proceso.
DATA_DIR=./data

# Si se define, TODOS los pedidos a /api/* deben mandar el header
# "Authorization: Bearer <este valor>". Generarlo con, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si se deja vacío/sin definir, el servidor arranca sin autenticación
# (imprime una advertencia al iniciar). Aceptable solo en localhost/red de
# confianza — nunca para exponer el servidor a internet público.
API_KEY=

# Debe coincidir con API_KEY de arriba. Se usa en build-time por Vite para
# que ui-nino mande el header Authorization correcto. Dejar vacío si el
# servidor corre sin autenticación.
VITE_API_KEY=
